@startuml delete-contract
!theme plain
title DELETE /api/v1/contracts/{id} — Delete Contract

actor Client
participant "ContractController" as Controller
participant "ContractService" as Service
participant "IContractRepository" as IRepo
database DB

Client -> Controller : DELETE /api/v1/contracts/{id}
activate Controller
Controller -> Service : delete(id)
activate Service

Service -> IRepo : deleteContract(id)
activate IRepo
IRepo -> DB : DELETE FROM contracts WHERE id = ?

alt not found (0 rows affected)
    IRepo --> Service : throw ContractNotFoundException
    Service --> Controller : ContractNotFoundException
    Controller --> Client : 404 CONTRACT_NOT_FOUND
else deleted
    DB --> IRepo : 1 row deleted (cascades contract_assets)
    IRepo --> Service : void
    deactivate IRepo
end

Service --> Controller : void
deactivate Service
Controller --> Client : 204 No Content
deactivate Controller
@enduml
